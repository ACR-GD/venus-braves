{
  "_comment": "Manifeste générique — adapter à votre jeu PS2",
  "original_iso": "game_original.iso",
  "output_iso": "game_translated.iso",
  "staging_dir": "staging",

  "archives": [
    {
      "name": "CDIMAGE.BIN",
      "iso_path": "IMAGE/CDIMAGE.BIN",
      "unpacked_dir": "cdimage_unpacked",
