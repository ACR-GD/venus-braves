      "max_size": null,
      "layout": null,
      "repack_before_build": true,
      "_note": "max_size = taille exacte dans l'ISO (ps2_iso.py inventory). layout null = auto."
    }
  ],

  "same_size_patches": [
    {
      "iso_path": "SLPS_XXX.XX",
      "source": "patched/SLPS_XXX.XX",
      "_note": "Exécutable EE modifié, MÊME taille obligatoire"
    }
  ],

  "replace_files": [
    {
      "iso_path": "IMAGE/CDIMAGE.BIN",
      "source": "staging/CDIMAGE.BIN",
      "check_extent": true,
      "pad_to_original": true
    }
  ]
}
